{
  "expo": {
    "name": "Encuentro con Jesús",
    "slug": "Encuentro",
    "scheme": "encuentro",
    "version": "1.0.0",
    "icon": "./assets/logo_v11.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash_v9.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0b0f"
    },
    "notification": {
      "icon": "./assets/logo_v11.png",
      "color": "#d4af37"
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-notifications",
      "expo-dev-client",
      "expo-web-browser",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f8627e38-0057-49eb-86d5-28c42bf2b268"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yorielinho10.encuentro",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_v11.png",
        "backgroundColor": "#0b0b0f"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yorielinho10.encuentro"
    },
    "web": {}
  }
}
