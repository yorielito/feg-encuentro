{
  "expo": {
    "name": "Encuentro con Jesús",
    "slug": "Encuentro",
    "scheme": "encuentro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": ["expo-notifications", "expo-dev-client", "expo-web-browser"],
    "extra": {
      "eas": {
        "projectId": "f8627e38-0057-49eb-86d5-28c42bf2b268"
      }
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yorielinho10.encuentro"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "package": "com.yorielinho10.encuentro",
        "googleServicesFile": "./google-services.json"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yorielinho10.encuentro"
    },
    "web": {}
  }
}